#!/bin/sh
# pre-commit hook: sync TOC status + review changed chapters (staged)
# Uses sh shebang so Git for Windows can execute it properly.

powershell.exe -NoProfile -ExecutionPolicy Bypass -File \
  "AndroidDeveloperGuideStory/review/scripts/sync_toc_status.ps1"
rc=$?
if [ $rc -ne 0 ]; then
  echo "pre-commit blocked: TOC sync failed."
  exit $rc
fi

# Stage TOC changes produced by sync script
git add -- 'AndroidDeveloperGuideStory/Contents/00-'*.md 2>/dev/null

powershell.exe -NoProfile -ExecutionPolicy Bypass -File \
  "AndroidDeveloperGuideStory/review/scripts/review_changed_chapters.ps1" \
  -Mode staged
rc=$?
if [ $rc -ne 0 ]; then
  echo "pre-commit blocked: chapter review failed."
  exit $rc
fi

exit 0
